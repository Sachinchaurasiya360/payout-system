# Copy to `.env` and adjust as needed.
# Matches the docker-compose.yml Postgres service below.
DATABASE_URL="postgresql://payout:payout@localhost:5432/payout_db?schema=public"

# HTTP port for the Express API
PORT=3000

# Payment gateway simulation:
#   - "auto"   : advance transfers succeed synchronously; withdrawals stay PENDING until /settle is called (default, best for the demo)
#   - "always" : every transfer succeeds immediately (advances complete, withdrawals auto-complete)
GATEWAY_MODE=auto
